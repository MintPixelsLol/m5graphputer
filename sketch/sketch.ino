  //ruler x
  if (graphDrawUI[0]) {
    Canvas.fillRect(0, 120, 240, 15, 0xBDF7);
    Canvas.drawLine(0, 119, 238, 119, 0x8410);
    Canvas.setTextSize(1);
    Canvas.setFreeFont(&Org_01);

    for (int ix = linesX; ix < 240 + linesX; ix++) {
      drawX = ix / 2;
      posX = ix - linesX;
